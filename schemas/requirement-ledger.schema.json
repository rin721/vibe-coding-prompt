{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Vibe Coding Requirement Ledger",
  "type": "object",
  "required": ["requirements"],
  "properties": {
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "source",
          "raw_text",
          "normalized_text",
          "type",
          "priority_or_version",
          "status",
          "decision",
          "related_slice",
          "conflicts",
          "evidence",
          "next_action",
          "updated_at"
        ],
        "properties": {
          "id": { "type": "string" },
          "source": { "type": "string" },
          "raw_text": { "type": "string" },
          "normalized_text": { "type": "string" },
          "type": { "type": "string" },
          "priority_or_version": { "type": "string" },
          "status": { "type": "string" },
          "decision": { "type": "string" },
          "related_slice": { "type": "array", "items": { "type": "string" } },
          "conflicts": { "type": "array", "items": { "type": "string" } },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "next_action": { "type": "string" },
          "updated_at": { "type": "string" }
        }
      }
    }
  }
}
