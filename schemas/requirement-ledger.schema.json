{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Requirement Ledger",
  "type": "object",
  "required": ["requirements"],
  "properties": {
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "source",
          "raw_text",
          "normalized_text",
          "type",
          "priority_or_version",
          "status",
          "decision",
          "related_slice",
          "conflicts",
          "evidence",
          "next_action",
          "updated_at"
        ]
      }
    }
  }
}
