{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Vibe Coding Execution Slices",
  "type": "object",
  "required": ["slices"],
  "properties": {
    "slices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "parent_task",
          "phase",
          "module",
          "goal",
          "inputs",
          "outputs",
          "allowed_files",
          "forbidden_files",
          "allowed_tools",
          "approval_required_for",
          "risk_level",
          "agency_level",
          "verification",
          "acceptance",
          "rollback_plan",
          "max_iterations",
          "max_retries",
          "audit_evidence",
          "human_override",
          "status",
          "next_condition",
          "updated_at"
        ]
      }
    }
  }
}
