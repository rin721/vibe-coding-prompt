{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Status",
  "type": "object",
  "required": ["status_items"],
  "properties": {
    "status_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "phase",
          "module",
          "depends_on",
          "risk_level",
          "allowed_files",
          "forbidden_files",
          "verification",
          "evidence",
          "next_condition",
          "actor",
          "agent_or_model",
          "authorization_source",
          "tool_calls",
          "input_trust_level",
          "agency_level",
          "human_override",
          "audit_evidence",
          "updated_at"
        ]
      }
    }
  }
}
