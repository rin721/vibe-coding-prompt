{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local/vibe/knowledge-entry.json",
  "title": "KnowledgeEntry",
  "type": "object",
  "required": ["id", "title", "body", "source_path", "source_kind", "trust_level", "status", "updated_at"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "body": { "type": "string", "minLength": 1 },
    "source_path": { "type": "string", "minLength": 1 },
    "source_kind": { "type": "string" },
    "trust_level": {
      "type": "string",
      "enum": ["official", "primary", "project", "community", "unverified"]
    },
    "status": {
      "type": "string",
      "enum": ["candidate", "reviewed", "stable", "deprecated"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": { "type": "object" },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": false
}
