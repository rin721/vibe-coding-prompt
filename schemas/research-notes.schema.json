{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Notes",
  "type": "object",
  "required": ["research_notes"],
  "properties": {
    "research_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "question",
          "trigger",
          "query_paths",
          "sources",
          "key_evidence",
          "conclusion",
          "confidence",
          "scope",
          "risks",
          "requires_developer_confirmation",
          "updated_at"
        ]
      }
    }
  }
}
